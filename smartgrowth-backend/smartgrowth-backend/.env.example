SECRET_KEY=change-this-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

DB_NAME=smartgrowth
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432

# Comma-separated origins allowed to call this API (React PWA dev server, deployed frontend, etc.)
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Optional, one-time only: seeds RegistrationInviteCode (accounts/models.py) the
# first time migrations run on a fresh DB. If unset, a random code is generated
# instead. Ignored after that first migration — the code lives in the DB from
# then on and is viewed/regenerated from the "Kode Posyandu" admin page, not here.
# KADER_NAKES_INVITE_CODE=

# --- Production (VPS) example — see DEPLOY.md ---
# SECRET_KEY=<generate a long random value, e.g. `python -c "import secrets; print(secrets.token_urlsafe(50))"`>
# DEBUG=False
# ALLOWED_HOSTS=smartgrowth.f-mc.my.id
# DB_NAME=smartgrowth
# DB_USER=smartgrowth
# DB_PASSWORD=<strong password, not the local dev one>
# DB_HOST=localhost
# DB_PORT=5432
# CORS_ALLOWED_ORIGINS=https://smartgrowth.f-mc.my.id
# CSRF_TRUSTED_ORIGINS=https://smartgrowth.f-mc.my.id
