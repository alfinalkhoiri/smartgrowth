# Used only for `npm run build:capacitor` (native Android/iOS builds via
# Capacitor) — NOT for the regular web build, which stays on the relative
# "/api" default (same-origin against nginx, see src/api/client.ts). A
# native WebView has no "origin" to resolve a relative path against, so it
# needs the real deployed backend URL spelled out.
VITE_API_BASE_URL=https://smartgrowth.f-mc.my.id/api
