# For local web dev, leave this unset (Vite dev server proxies /api).
# For production (VPS) web deploys where frontend + backend share one domain
# (see DEPLOY.md — smartgrowth.f-mc.my.id with nginx proxying /api to
# Django), ALSO leave this unset: '/api' relative still resolves correctly
# since it's the same origin, nginx just routes it server-side.
# Only set this for Capacitor builds (native app) — there's no dev-server or
# nginx proxy inside a native WebView, so it MUST be an absolute URL:
VITE_API_BASE_URL=https://smartgrowth.f-mc.my.id/api
